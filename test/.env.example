# RAG 系统配置文件示例
# 复制此文件为 .env 并填入实际配置

# 模型路径配置
MODEL_DIR=G:/si_safety/models
BGE_MODEL_PATH=G:/si_safety/models/bge-m3
RERANKER_MODEL_PATH=G:/si_safety/models/bge-reranker-v2-m3

# Milvus 配置
MILVUS_HOST=192.168.150.131 
MILVUS_PORT=19530
COLLECTION_NAME=bge_m3_rag_vectors

# LLM 配置
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# HuggingFace 配置
HF_HOME=G:/si_safety/models
HUGGINGFACE_HUB_CACHE=G:/si_safety/models
HF_ENDPOINT=https://hf-mirror.com
TRANSFORMERS_CACHE=G:/si_safety/models
